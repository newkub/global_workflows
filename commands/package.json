{
	"name": "global-workflows-commands",
	"version": "1.0.0",
	"description": "CLI commands for global workflows management",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"check-unused-workflows": "dist/src/presentation/cli/check-unused-workflows.js",
		"check-file-length": "dist/src/presentation/cli/check-file-length.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"dev": "bun run src/cli",
		"build": "bunup",
		"build:watch": "bunup --watch",
		"test": "vitest",
		"test:coverage": "vitest --coverage",
		"lint": "biome lint",
		"lint:fix": "biome lint --write",
		"format": "biome format --write",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"release": "release-it"
	},
	"keywords": [
		"workflows",
		"cli",
		"typescript"
	],
	"author": "Veerapong",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/newkub/global_workflows.git"
	},
	"homepage": "https://github.com/newkub/global_workflows#readme",
	"private": false,
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/bun": "^1.3.14",
		"@types/node": "^20.19.41",
		"@vitest/coverage-v8": "^1.6.1",
		"bunup": "^0.16.31",
		"release-it": "^20.0.1",
		"tsx": "^4.22.3",
		"typescript": "^5.9.3",
		"vitest": "^1.6.1"
	},
	"dependencies": {
		"cac": "^7.0.0"
	}
}
